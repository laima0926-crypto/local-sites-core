---
import type { SiteConfig } from '../schema';
import Icon from './Icon.astro';
import { telAttrs } from '../obfuscate';
interface Props {
  site: SiteConfig;
}
const { site } = Astro.props;

const isRestaurant = site.businessType === 'restaurant';

// The /gallery page hosts the photo grid and before/after pairs. With neither,
// the page redirects home — so don't link to it from the nav.
const hasGalleryPage = site.gallery.length > 0 || site.beforeAfter.length > 0;

const nav = [
  { href: '/', label: 'Home' },
  isRestaurant ? { href: '/menu', label: 'Menu' } : { href: '/services', label: 'Services' },
  ...(hasGalleryPage ? [{ href: '/gallery', label: 'Gallery' }] : []),
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

// Bookings/enquiries live on the contact page (which carries optional date/time).
// Restaurants keep an external reservation link if they have one.
const ctaLabel = isRestaurant ? 'Get in touch' : 'Get a free quote';
const ctaHref = isRestaurant ? (site.reservationUrl || '/contact') : '/contact';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="sticky top-0 z-40 bg-white/95 backdrop-blur border-b border-ink-100">
  <div class="mx-auto max-w-6xl px-5 py-2.5 flex items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2 font-display font-bold text-lg text-ink-900 tracking-tight leading-tight">
      {site.business.logo
        ? <img src={site.business.logo} alt={site.business.name} class="h-12 md:h-14 w-auto max-w-[200px] object-contain" />
        : <span><span class="text-brand-600">✦</span> {site.business.name}</span>}
    </a>

    <nav class="hidden md:flex items-center gap-6 text-sm text-ink-700 font-medium" aria-label="Primary">
      {nav.map((item) => {
        const isActive = item.href === '/' ? pathname === '/' : pathname.startsWith(item.href);
        return (
          <a
            href={item.href}
            class={`hover:text-brand-700 transition-colors ${isActive ? 'text-brand-700' : ''}`}
            aria-current={isActive ? 'page' : undefined}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={ctaHref}
        class="hidden sm:inline-flex items-center gap-2 rounded-full bg-brand-600 hover:bg-brand-700 text-white text-sm font-semibold px-5 py-2.5 shadow-sm transition-colors"
      >
        {ctaLabel}
      </a>
      <a
        href="/contact"
        {...telAttrs(site.contact.phone)}
        class="sm:hidden inline-flex items-center gap-2 rounded-full bg-brand-600 hover:bg-brand-700 text-white text-sm font-semibold px-4 py-2"
        aria-label="Call us"
      >
        <Icon name="phone" class="w-4 h-4" /> Call
      </a>

      <button
        id="mobile-menu-toggle"
        type="button"
        class="md:hidden inline-flex items-center justify-center w-10 h-10 rounded-lg text-ink-700 hover:bg-ink-100"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-ink-100 bg-white">
    <nav class="px-5 py-4 flex flex-col gap-1 text-base font-medium" aria-label="Mobile">
      {nav.map((item) => {
        const isActive = item.href === '/' ? pathname === '/' : pathname.startsWith(item.href);
        return (
          <a
            href={item.href}
            class={`py-2.5 px-3 rounded-lg hover:bg-ink-50 ${isActive ? 'text-brand-700 bg-brand-50' : 'text-ink-700'}`}
          >
            {item.label}
          </a>
        );
      })}
      <a href="/contact" {...telAttrs(site.contact.phone, site.contact.phoneDisplay)} class="mt-3 py-2.5 px-3 rounded-lg bg-ink-50 text-ink-900 flex items-center gap-2">
        <Icon name="phone" class="w-4 h-4" /> <span data-v>Call us</span>
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      menu.classList.toggle('hidden');
    });
  }
</script>
