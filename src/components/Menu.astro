---
import type { SiteConfig } from '../schema';
interface Props {
  site: SiteConfig;
  preview?: boolean;
  previewHeading?: string;
  previewIntro?: string;
}
const {
  site,
  preview = false,
  previewHeading = 'A taste of our menu',
  previewIntro = 'A few of our favourites. See the full menu for everything we serve.',
} = Astro.props;

const menu = site.menu ?? [];
// On the homepage preview, show just the first section so the page stays light.
const sections = preview ? menu.slice(0, 1) : menu;

const TAG_LABELS: Record<string, string> = {
  V: 'Vegetarian',
  VG: 'Vegan',
  GF: 'Gluten-free',
  DF: 'Dairy-free',
  N: 'Contains nuts',
  S: 'Spicy',
};
---

<section class="py-20 md:py-24 bg-white">
  <div class="mx-auto max-w-4xl px-5">
    <div class="max-w-2xl">
      <p class="text-brand-700 font-semibold text-sm uppercase tracking-wider">Menu</p>
      <h2 class="mt-3 font-display text-3xl md:text-4xl font-extrabold tracking-tight text-ink-900">
        {preview ? previewHeading : 'Our menu'}
      </h2>
      <p class="mt-4 text-lg text-ink-600 leading-relaxed">
        {preview ? previewIntro : (site.menuNote || 'Freshly prepared to order. Please let us know about any allergies and we’ll do our best to help.')}
      </p>
    </div>

    {!preview && site.menuNote && (
      <p class="mt-6 text-sm text-ink-500 bg-ink-50 border border-ink-100 rounded-xl px-4 py-3">
        {site.menuNote}
      </p>
    )}

    <div class="mt-12 space-y-14">
      {sections.map((section) => (
        <div>
          <div class="flex items-baseline gap-3 border-b-2 border-brand-100 pb-2">
            <h3 class="font-display text-2xl font-extrabold text-ink-900">{section.name}</h3>
            {section.description && (
              <span class="text-sm text-ink-500">{section.description}</span>
            )}
          </div>

          <ul class="mt-6 space-y-6">
            {section.items.map((item) => (
              <li>
                <div class="flex items-baseline gap-3">
                  <h4 class="font-display font-bold text-ink-900 flex items-center gap-2 flex-wrap">
                    {item.name}
                    {item.tags && item.tags.map((tag) => (
                      <span
                        class="inline-flex items-center justify-center rounded-full bg-brand-50 border border-brand-200 text-brand-700 text-[10px] font-bold w-5 h-5"
                        title={TAG_LABELS[tag] || tag}
                      >
                        {tag}
                      </span>
                    ))}
                  </h4>
                  <span class="flex-1 border-b border-dotted border-ink-200 translate-y-[-3px]"></span>
                  <span class="font-display font-bold text-brand-700 whitespace-nowrap">{item.price}</span>
                </div>
                {item.description && (
                  <p class="mt-1 text-sm text-ink-600 leading-relaxed max-w-prose">{item.description}</p>
                )}
                {item.allergens && (
                  <p class="mt-1 text-xs text-ink-400">{item.allergens}</p>
                )}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    {preview && (
      <div class="mt-12 text-center">
        <a href="/menu" class="inline-flex items-center gap-2 rounded-full bg-white border-2 border-brand-600 text-brand-700 hover:bg-brand-50 font-semibold px-7 py-3 transition-colors">
          See the full menu
          <span aria-hidden="true">→</span>
        </a>
      </div>
    )}

    {!preview && site.delivery && site.delivery.length > 0 && (
      <div class="mt-16 rounded-2xl bg-ink-50 border border-ink-100 p-6 md:p-8 text-center">
        <h3 class="font-display text-xl font-bold text-ink-900">Order in</h3>
        <p class="mt-2 text-sm text-ink-600">Get our food delivered to your door.</p>
        <div class="mt-5 flex flex-wrap gap-3 justify-center">
          {site.delivery.map((d) => (
            <a
              href={d.url}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 rounded-full bg-white border border-ink-200 hover:border-brand-300 text-ink-800 font-semibold px-5 py-2.5 transition-colors"
            >
              {d.name}
              <span aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</section>
