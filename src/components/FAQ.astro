---
import type { SiteConfig } from '../schema';
interface Props {
  site: SiteConfig;
  heading?: string;
  limit?: number;
}
const { site, heading = 'Frequently asked questions', limit } = Astro.props;
const items = limit ? site.faq.slice(0, limit) : site.faq;
---

{items.length > 0 && (
  <section class="py-20 md:py-24 bg-ink-50">
    <div class="mx-auto max-w-3xl px-5">
      <h2 class="font-display text-3xl md:text-4xl font-extrabold tracking-tight text-ink-900 text-center">
        {heading}
      </h2>

      <div class="mt-10 space-y-3">
        {items.map((item) => (
          <details class="group bg-white rounded-xl border border-ink-100 overflow-hidden">
            <summary class="flex justify-between items-center gap-4 cursor-pointer px-5 py-4 font-semibold text-ink-900 hover:bg-ink-50">
              <span>{item.question}</span>
              <svg class="w-5 h-5 text-ink-500 transition-transform group-open:rotate-180 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 pb-5 text-ink-700 leading-relaxed">
              {item.answer}
            </div>
          </details>
        ))}
      </div>

      {limit && site.faq.length > limit && (
        <div class="mt-8 text-center">
          <a href="/about#faq" class="text-brand-700 font-semibold hover:underline">See all FAQs →</a>
        </div>
      )}
    </div>
  </section>
)}
