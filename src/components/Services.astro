---
import type { SiteConfig } from '../schema';
interface Props {
  site: SiteConfig;
  preview?: boolean;
  previewHeading?: string;
  previewIntro?: string;
  fullHeading?: string;
  fullIntro?: string;
}
const {
  site,
  preview = false,
  previewHeading = 'Our most popular services',
  previewIntro = "A selection of what we offer. See the full list and what's included on the services page.",
  fullHeading = 'Services & pricing',
  fullIntro = "All prices are starting prices for a typical job in our standard service area. We'll always confirm the exact quote in writing before any work begins.",
} = Astro.props;
const services = preview ? site.services.slice(0, 3) : site.services;
const heading = preview ? previewHeading : fullHeading;
const intro = preview ? previewIntro : fullIntro;
---

<section class="py-20 md:py-24 bg-white">
  <div class="mx-auto max-w-6xl px-5">
    <div class="max-w-2xl">
      <p class="text-brand-700 font-semibold text-sm uppercase tracking-wider">Our services</p>
      <h2 class="mt-3 font-display text-3xl md:text-4xl font-extrabold tracking-tight text-ink-900">
        {heading}
      </h2>
      <p class="mt-4 text-lg text-ink-600 leading-relaxed">
        {intro}
      </p>
    </div>

    <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {services.map((service) => (
        <article class="rounded-2xl border border-ink-100 bg-white p-6 hover:border-brand-200 hover:shadow-md transition-all flex flex-col">
          {service.icon && (
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-brand-50 text-2xl">
              {service.icon}
            </div>
          )}
          <h3 class="mt-5 font-display text-lg font-bold text-ink-900">{service.name}</h3>
          <p class="mt-2 text-ink-600 leading-relaxed text-sm">{service.description}</p>

          {!preview && service.whoFor && (
            <Fragment>
              <p class="mt-4 text-xs font-semibold uppercase tracking-wider text-ink-500">Good for</p>
              <p class="mt-1 text-sm text-ink-700">{service.whoFor}</p>
            </Fragment>
          )}

          {!preview && service.included && service.included.length > 0 && (
            <Fragment>
              <p class="mt-4 text-xs font-semibold uppercase tracking-wider text-ink-500">What's included</p>
              <ul class="mt-2 space-y-1.5">
                {service.included.map((item) => (
                  <li class="flex items-start gap-2 text-sm text-ink-700">
                    <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-brand-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                      <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                    </svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </Fragment>
          )}

          <div class="mt-5 pt-5 border-t border-ink-100 flex items-center justify-between gap-3 mt-auto">
            <span class="text-brand-700 font-bold text-base">{service.price}</span>
            <a href="/contact" class="text-sm font-semibold text-ink-600 hover:text-brand-700 transition-colors whitespace-nowrap">
              Get quote →
            </a>
          </div>
        </article>
      ))}
    </div>

    {preview && (
      <div class="mt-10 text-center">
        <a href="/services" class="inline-flex items-center gap-2 rounded-full bg-white border-2 border-brand-600 text-brand-700 hover:bg-brand-50 font-semibold px-7 py-3 transition-colors">
          See all services &amp; pricing
          <span aria-hidden="true">→</span>
        </a>
      </div>
    )}
  </div>
</section>
