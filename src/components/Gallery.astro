---
import type { SiteConfig } from '../schema';
interface Props {
  site: SiteConfig;
}
const { site } = Astro.props;
const categories = ['All', ...Array.from(new Set(site.gallery.map((g) => g.category).filter(Boolean)))];
const isRestaurant = site.businessType === 'restaurant';
const galleryHeading = isRestaurant
  ? 'A taste of what we serve'
  : (site.contact.serviceAreas?.[0]
      ? `Recent work in ${site.contact.serviceAreas[0]}`
      : 'Our recent work');
const galleryIntro = isRestaurant
  ? 'A look at our food. Click any photo to see it larger.'
  : 'Real photos from real jobs. Click any image to see it larger.';
---

<section class="py-20 md:py-24 bg-white">
  <div class="mx-auto max-w-6xl px-5">
    <div class="max-w-2xl">
      <p class="text-brand-700 font-semibold text-sm uppercase tracking-wider">Gallery</p>
      <h2 class="mt-3 font-display text-3xl md:text-4xl font-extrabold tracking-tight text-ink-900">
        {galleryHeading}
      </h2>
      <p class="mt-4 text-lg text-ink-600 leading-relaxed">
        {galleryIntro}
      </p>
    </div>

    <div class="mt-10 flex flex-wrap gap-2" role="tablist" aria-label="Gallery filters">
      {categories.map((cat, i) => (
        <button
          type="button"
          data-filter={cat}
          class={`gallery-filter rounded-full px-4 py-2 text-sm font-medium transition-colors ${i === 0 ? 'bg-brand-600 text-white' : 'bg-ink-100 text-ink-700 hover:bg-ink-200'}`}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
        >
          {cat}
        </button>
      ))}
    </div>

    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3" id="gallery-grid">
      {site.gallery.map((item) => (
        <figure
          class="gallery-item group cursor-pointer"
          data-category={item.category}
          data-src={item.src}
          data-caption={item.caption || ''}
          data-alt={item.alt}
        >
          <div class="relative aspect-[4/3] rounded-2xl overflow-hidden bg-ink-100 shadow-sm group-hover:shadow-lg transition-shadow">
            <img
              src={item.src}
              alt={item.alt}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-ink-900/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            {item.category && (
              <span class="absolute top-3 left-3 inline-block bg-white/90 backdrop-blur text-ink-800 text-xs font-semibold px-2.5 py-1 rounded-full">
                {item.category}
              </span>
            )}
          </div>
          {item.caption && (
            <figcaption class="mt-2 text-sm text-ink-600">{item.caption}</figcaption>
          )}
        </figure>
      ))}
    </div>
  </div>
</section>

<!-- Lightbox -->
<div id="lightbox" class="hidden fixed inset-0 z-50 bg-ink-900/90 backdrop-blur items-center justify-center p-4" role="dialog" aria-modal="true" aria-label="Image preview">
  <button id="lightbox-close" type="button" class="absolute top-4 right-4 text-white w-12 h-12 rounded-full bg-white/10 hover:bg-white/20 inline-flex items-center justify-center" aria-label="Close">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
  </button>
  <figure class="max-w-5xl w-full">
    <img id="lightbox-img" src="" alt="" class="w-full max-h-[80vh] object-contain rounded-lg" />
    <figcaption id="lightbox-caption" class="mt-3 text-center text-sm text-white/90"></figcaption>
  </figure>
</div>

<script>
  const filters = document.querySelectorAll<HTMLButtonElement>('.gallery-filter');
  const items = document.querySelectorAll<HTMLElement>('.gallery-item');

  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;

      filters.forEach((f) => {
        const active = f === btn;
        f.classList.toggle('bg-brand-600', active);
        f.classList.toggle('text-white', active);
        f.classList.toggle('bg-ink-100', !active);
        f.classList.toggle('text-ink-700', !active);
        f.setAttribute('aria-selected', String(active));
      });

      items.forEach((item) => {
        const matches = filter === 'All' || item.dataset.category === filter;
        item.classList.toggle('hidden', !matches);
      });
    });
  });

  const lightbox = document.getElementById('lightbox')!;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxCaption = document.getElementById('lightbox-caption')!;
  const lightboxClose = document.getElementById('lightbox-close')!;

  function openLightbox(src: string, caption: string, alt: string) {
    lightboxImg.src = src;
    lightboxImg.alt = alt; // accessibility only — not shown on screen
    lightboxCaption.textContent = caption; // visible caption: only what the customer wrote
    lightboxCaption.classList.toggle('hidden', !caption);
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    document.body.style.overflow = '';
  }

  items.forEach((item) => {
    item.addEventListener('click', () => {
      const src = item.dataset.src || '';
      const caption = item.dataset.caption || '';
      const alt = item.dataset.alt || '';
      openLightbox(src, caption, alt);
    });
  });

  lightboxClose.addEventListener('click', closeLightbox);
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !lightbox.classList.contains('hidden')) closeLightbox();
  });
</script>
