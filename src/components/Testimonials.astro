---
import type { SiteConfig } from '../schema';
interface Props {
  site: SiteConfig;
  heading?: string;
  subheading?: string;
}
const { site, heading = 'What customers say', subheading } = Astro.props;
---

<section class="py-20 md:py-24 bg-brand-600 text-white relative overflow-hidden">
  <div class="absolute -top-32 -left-32 w-96 h-96 bg-brand-500/40 rounded-full blur-3xl"></div>
  <div class="absolute -bottom-32 -right-32 w-96 h-96 bg-brand-700/40 rounded-full blur-3xl"></div>

  <div class="relative mx-auto max-w-6xl px-5">
    <div class="text-center max-w-2xl mx-auto">
      <p class="text-brand-100 font-semibold text-sm uppercase tracking-wider">In their own words</p>
      <h2 class="mt-3 font-display text-3xl md:text-4xl font-extrabold tracking-tight">
        {heading}
      </h2>
      {subheading && (
        <p class="mt-4 text-lg text-brand-100 leading-relaxed">{subheading}</p>
      )}
      {site.socials.googleBusinessProfile && (
        <p class="mt-4 text-sm text-brand-100">
          More reviews on our <a href={site.socials.googleBusinessProfile} class="underline font-medium hover:text-white" target="_blank" rel="noopener">Google Business Profile</a>.
        </p>
      )}
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {site.testimonials.map((t) => (
        <blockquote class="bg-white/10 backdrop-blur rounded-2xl p-6 border border-white/20">
          <p class="text-brand-50 leading-relaxed">"{t.quote}"</p>
          <footer class="mt-5 pt-5 border-t border-white/20 text-sm">
            <div class="font-semibold text-white">{t.name}</div>
            <div class="text-brand-200 mt-0.5">
              {t.location}{t.service && ` · ${t.service}`}
            </div>
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>
