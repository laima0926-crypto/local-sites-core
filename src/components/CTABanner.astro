---
// Shared call-to-action banner. Prop-driven so any template can use it.
interface Props {
  phone: string;
  phoneDisplay: string;
  heading?: string;
  subheading?: string;
}
const { phone, phoneDisplay, heading = 'Ready to get started?', subheading } = Astro.props;
---

<section class="bg-brand-700 text-white">
  <div class="mx-auto max-w-5xl px-5 py-16 md:py-20 text-center">
    <h2 class="font-display text-3xl md:text-4xl font-extrabold tracking-tight">{heading}</h2>
    {subheading && <p class="mt-3 text-lg text-white/90 max-w-2xl mx-auto leading-relaxed">{subheading}</p>}
    <div class="mt-8 flex flex-wrap gap-3 justify-center">
      <a
        href={`tel:${phone}`}
        class="inline-flex items-center gap-2 rounded-full bg-white text-brand-700 font-semibold px-6 py-3 hover:bg-brand-50 transition-colors"
      >
        📞 Call {phoneDisplay}
      </a>
      <a
        href="#contact"
        class="inline-flex items-center gap-2 rounded-full border-2 border-white/70 text-white font-semibold px-6 py-3 hover:bg-white/10 transition-colors"
      >
        Get a free quote
      </a>
    </div>
  </div>
</section>
