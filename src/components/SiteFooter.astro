---
import type { SiteConfig } from '../schema';
interface Props {
  site: SiteConfig;
}
const { site } = Astro.props;
const year = new Date().getFullYear();
const isRestaurant = site.businessType === 'restaurant';
// Mirror the header: only link the /gallery page when it has content.
const hasGalleryPage = site.gallery.length > 0 || site.beforeAfter.length > 0;
---

<footer class="bg-ink-900 text-ink-400 border-t border-ink-800">
  <div class="mx-auto max-w-6xl px-5 py-12">
    <div class="grid gap-8 md:grid-cols-4">
      <div class="md:col-span-2">
        <p class="font-display font-bold text-lg text-white tracking-tight">
          <span class="text-brand-500">✦</span> {site.business.name}
        </p>
        <p class="mt-3 text-sm leading-relaxed max-w-sm">
          {site.business.shortDescription}
        </p>

        <ul class="mt-5 space-y-2 text-sm">
          <li><a href={`tel:${site.contact.phone}`} class="hover:text-white transition-colors">📞 {site.contact.phoneDisplay}</a></li>
          {site.contact.email && <li><a href={`mailto:${site.contact.email}`} class="hover:text-white transition-colors">✉️ {site.contact.email}</a></li>}
          <li class="text-ink-500">📍 {site.contact.addressLines.join(', ')}</li>
        </ul>
      </div>

      <div>
        <h4 class="font-display font-semibold text-white mb-3">Site</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
          {isRestaurant
            ? <li><a href="/menu" class="hover:text-white transition-colors">Menu</a></li>
            : <li><a href="/services" class="hover:text-white transition-colors">Services</a></li>}
          {hasGalleryPage && <li><a href="/gallery" class="hover:text-white transition-colors">Gallery</a></li>}
          <li><a href="/about" class="hover:text-white transition-colors">About</a></li>
          <li><a href="/contact" class="hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-display font-semibold text-white mb-3">Follow us</h4>
        <ul class="space-y-2 text-sm">
          {site.socials.facebook && <li><a href={site.socials.facebook} target="_blank" rel="noopener" class="hover:text-white transition-colors">Facebook</a></li>}
          {site.socials.instagram && <li><a href={site.socials.instagram} target="_blank" rel="noopener" class="hover:text-white transition-colors">Instagram</a></li>}
          {site.socials.googleBusinessProfile && <li><a href={site.socials.googleBusinessProfile} target="_blank" rel="noopener" class="hover:text-white transition-colors">Google Business</a></li>}
          {site.socials.checkatrade && <li><a href={site.socials.checkatrade} target="_blank" rel="noopener" class="hover:text-white transition-colors">Checkatrade</a></li>}
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-8 border-t border-ink-800 flex flex-col sm:flex-row gap-3 justify-between text-sm">
      <p>&copy; {year} {site.business.legalName || site.business.name}. All rights reserved.</p>
      <p class="text-ink-500">
        Website by <a href="https://createmywebsite.co.uk" class="hover:text-brand-400 transition-colors">createmywebsite.co.uk</a>
      </p>
    </div>
  </div>
</footer>
