---
import type { SiteConfig } from '../schema';
import { telAttrs, waAttrs } from '../obfuscate';
interface Props {
  site: SiteConfig;
}
const { site } = Astro.props;
const waNumber = site.contact.whatsapp?.replace(/\D/g, '');

// Factual coverage line — only states what the customer actually provided.
const c = site.contact;
const hasAddress = c.addressLines.length > 0;
const coverage = c.nationwide
  ? 'Covering all of the UK. Get in touch wherever you are.'
  : hasAddress && c.travelRadius
    ? `Based in ${c.addressLines.join(', ')}. Mobile appointments within ${c.travelRadius} miles.`
    : hasAddress
      ? `Based in ${c.addressLines.join(', ')}.`
      : c.travelRadius && c.serviceAreas[0]
        ? `Mobile service within ${c.travelRadius} miles of ${c.serviceAreas[0]}.`
        : c.serviceAreas[0]
          ? `Covering ${c.serviceAreas[0]}.`
          : '';
---

<aside class="space-y-5">
  <div class="rounded-2xl bg-brand-50 p-6 border border-brand-100">
    <h3 class="font-display font-bold text-ink-900 mb-3 flex items-center gap-2">
      <span aria-hidden="true">📞</span> Call us
    </h3>
    <a href="/contact" {...telAttrs(site.contact.phone, site.contact.phoneDisplay)} class="block text-2xl font-display font-extrabold text-brand-700 hover:underline">
      <span data-v>Tap to call</span>
    </a>
  </div>

  {site.contact.whatsapp && waNumber && (
    <div class="rounded-2xl bg-white p-6 border border-ink-100">
      <h3 class="font-display font-bold text-ink-900 mb-3 flex items-center gap-2">
        <span aria-hidden="true">💬</span> WhatsApp
      </h3>
      <a href="/contact" {...waAttrs(waNumber)} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full bg-[#25D366] hover:bg-[#1ebd58] text-white text-sm font-semibold px-5 py-2.5">
        Message us on WhatsApp
      </a>
    </div>
  )}

  {site.contact.email && (
    <div class="rounded-2xl bg-white p-6 border border-ink-100">
      <h3 class="font-display font-bold text-ink-900 mb-3 flex items-center gap-2">
        <span aria-hidden="true">✉️</span> Prefer to write?
      </h3>
      <p class="text-sm text-ink-700">Use the enquiry form on this page and your message lands straight in our inbox.</p>
    </div>
  )}

  {site.delivery && site.delivery.length > 0 && (
    <div class="rounded-2xl bg-white p-6 border border-ink-100">
      <h3 class="font-display font-bold text-ink-900 mb-3 flex items-center gap-2">
        <span aria-hidden="true">🛵</span> Order online
      </h3>
      <div class="flex flex-wrap gap-2">
        {site.delivery.map((d) => (
          <a href={d.url} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-full bg-white border border-ink-200 hover:border-brand-300 text-ink-800 text-sm font-semibold px-4 py-2 transition-colors">
            {d.name} <span aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  )}

  <div class="rounded-2xl bg-white p-6 border border-ink-100">
    <h3 class="font-display font-bold text-ink-900 mb-3 flex items-center gap-2">
      <span aria-hidden="true">🕒</span> Opening hours
    </h3>
    <ul class="space-y-2 text-sm">
      {site.hours.map((row) => (
        <li class="flex justify-between text-ink-700">
          <span>{row.day}</span>
          <span class="font-medium text-ink-900">{row.hours}</span>
        </li>
      ))}
    </ul>
  </div>

  <div class="rounded-2xl bg-white p-6 border border-ink-100">
    <h3 class="font-display font-bold text-ink-900 mb-2 flex items-center gap-2">
      <span aria-hidden="true">📍</span> Where we work
    </h3>
    <p class="text-sm text-ink-700 leading-relaxed">
      {coverage}
    </p>
  </div>
</aside>
