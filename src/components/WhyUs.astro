---
import type { SiteConfig } from '../schema';
interface Props {
  site: SiteConfig;
  heading?: string;
}
const { site, heading = 'A team you can rely on, visit after visit.' } = Astro.props;
---

<section class="py-20 md:py-24 bg-ink-50">
  <div class="mx-auto max-w-6xl px-5 grid md:grid-cols-2 gap-10 items-center">
    <div>
      <p class="text-brand-700 font-semibold text-sm uppercase tracking-wider">Why choose us</p>
      <h2 class="mt-3 font-display text-3xl md:text-4xl font-extrabold tracking-tight text-ink-900">
        {heading}
      </h2>
      <p class="mt-4 text-lg text-ink-600 leading-relaxed">
        {site.business.longDescription.split('\n\n')[0]}
      </p>
      <a href="/about" class="mt-6 inline-flex items-center gap-2 text-brand-700 font-semibold hover:underline">
        More about us <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="grid gap-3">
      {site.whyChooseUs.map((reason) => (
        <div class="flex items-start gap-3 bg-white rounded-xl p-4 border border-ink-100">
          <svg class="w-5 h-5 mt-0.5 flex-shrink-0 text-brand-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
          </svg>
          <span class="text-sm font-medium text-ink-800 leading-relaxed">{reason}</span>
        </div>
      ))}
    </div>
  </div>
</section>
