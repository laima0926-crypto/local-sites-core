---
import type { SiteConfig } from '../schema';
interface Props {
  site: SiteConfig;
}
const { site } = Astro.props;
---

{site.beforeAfter.length > 0 && (
  <section class="py-20 md:py-24 bg-gradient-to-b from-ink-50 to-white">
    <div class="mx-auto max-w-6xl px-5">
      <div class="max-w-2xl">
        <p class="text-brand-700 font-semibold text-sm uppercase tracking-wider">Before &amp; after</p>
        <h2 class="mt-3 font-display text-3xl md:text-4xl font-extrabold tracking-tight text-ink-900">
          See the difference for yourself
        </h2>
        <p class="mt-4 text-lg text-ink-600 leading-relaxed">
          Real photos from recent jobs.
        </p>
      </div>

      <div class="mt-12 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {site.beforeAfter.map((item) => (
          <figure>
            <div class="grid grid-cols-2 gap-1 rounded-2xl overflow-hidden shadow-md">
              <div class="relative">
                <img src={item.before} alt={`Before — ${item.alt}`} class="w-full aspect-square object-cover" loading="lazy" />
                <span class="absolute top-2 left-2 bg-ink-900/80 text-white text-xs font-semibold px-2 py-1 rounded">Before</span>
              </div>
              <div class="relative">
                <img src={item.after} alt={`After — ${item.alt}`} class="w-full aspect-square object-cover" loading="lazy" />
                <span class="absolute top-2 right-2 bg-brand-600 text-white text-xs font-semibold px-2 py-1 rounded">After</span>
              </div>
            </div>
            <figcaption class="mt-3 text-sm font-medium text-ink-700">
              {item.title}
            </figcaption>
          </figure>
        ))}
      </div>

      <div class="mt-10 text-center">
        <a href="/gallery" class="inline-flex items-center gap-2 rounded-full bg-white border-2 border-brand-600 text-brand-700 hover:bg-brand-50 font-semibold px-7 py-3 transition-colors">
          See the full gallery
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>
)}
