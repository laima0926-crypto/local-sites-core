---
import type { SiteConfig } from '../schema';
interface Props {
  site: SiteConfig;
}
const { site } = Astro.props;
// Only the pet generator populates this. Renders nothing without data, so it's
// safe to drop into any page — the section simply disappears when empty.
const animals = site.petAnimals ?? [];
---

{animals.length > 0 && (
  <section class="py-20 md:py-24 bg-ink-50">
    <div class="mx-auto max-w-6xl px-5 text-center">
      <p class="text-brand-700 font-semibold text-sm uppercase tracking-wider">Pets we groom</p>
      <h2 class="mt-3 font-display text-3xl md:text-4xl font-extrabold tracking-tight text-ink-900">
        The animals we look after
      </h2>
      <p class="mt-4 text-lg text-ink-600 leading-relaxed max-w-2xl mx-auto">
        Not sure if we groom your pet? Just ask, we're happy to help.
      </p>

      <ul class="mt-10 flex flex-wrap justify-center gap-2 max-w-3xl mx-auto">
        {animals.map((a) => (
          <li class="inline-flex items-center gap-2 rounded-full bg-white border border-brand-200 text-brand-800 text-sm font-medium px-4 py-2 shadow-sm">
            <span class="text-brand-600">🐾</span>
            {a}
          </li>
        ))}
      </ul>
    </div>
  </section>
)}
